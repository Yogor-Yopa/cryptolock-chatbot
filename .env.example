# Example .env file — copy to .env and fill values
VERIFY_TOKEN=your_verify_token_here
GEMINI_API_KEY=your_gemini_api_key_here
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here
PHONE_NUMBER_ID=your_phone_number_id_here
# Optional
DEBUG=False
# Variáveis de Ambiente - CryptoLock Chatbot
# Copie este arquivo para .env e preencha com seus valores reais

# Token de verificação do webhook (qualquer string - defina na Meta App)
VERIFY_TOKEN=seu_token_de_verificacao_aqui

# Chave de API da Google Gemini
GEMINI_API_KEY=sua_chave_gemini_aqui

# Token de acesso da API do WhatsApp Cloud
WHATSAPP_API_TOKEN=seu_token_whatsapp_aqui

# ID do número de telefone do WhatsApp Business
PHONE_NUMBER_ID=seu_phone_number_id_aqui
